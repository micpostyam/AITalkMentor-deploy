# === DATABASE ===
POSTGRES_DB=aitalkmentor_staging
POSTGRES_USER=aitalkmentor_staging_user
POSTGRES_PASSWORD=CHANGE_ME_staging_password_here

# === BACKEND ===
DATABASE_URL=postgresql://aitalkmentor_staging_user:CHANGE_ME_staging_password_here@db:5432/aitalkmentor_staging
SECRET_KEY=CHANGE_ME_staging_secret_key
ENVIRONMENT=staging
DEBUG=true

# === CORS ===
BACKEND_CORS_ORIGINS=https://staging.aitalkmentor.fr
FRONTEND_URL=https://staging.aitalkmentor.fr

# === GOOGLE OAUTH ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api-staging.aitalkmentor.fr/api/v1/oauth/google/callback

