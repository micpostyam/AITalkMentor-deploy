# === DATABASE ===
POSTGRES_DB=aitalkmentor_prod
POSTGRES_USER=aitalkmentor_prod_user
POSTGRES_PASSWORD=CHANGE_ME_strong_production_password

# === BACKEND ===
DATABASE_URL=postgresql://aitalkmentor_prod_user:CHANGE_ME_strong_production_password@db:5432/aitalkmentor_prod
SECRET_KEY=CHANGE_ME_production_secret_key
ENVIRONMENT=production
DEBUG=false

# === CORS ===
BACKEND_CORS_ORIGINS=https://aitalkmentor.fr,https://www.aitalkmentor.fr,https://aitalkmentor.com,https://www.aitalkmentor.com
FRONTEND_URL=https://aitalkmentor.fr

# === GOOGLE OAUTH ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.aitalkmentor.fr/api/v1/oauth/google/callback

# === EMAIL ===
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@aitalkmentor.fr
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587

# === MISTRAL DOCUMENT AI ===
AZURE_MISTRAL_DOC_API_KEY=
AZURE_MISTRAL_DOC_ENDPOINT=

